{
  "entities": {
    "ShopeeProduct": {
      "title": "ShopeeProduct",
      "description": "Product catalog item available for Jastip order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "originalPrice": { "type": "number" },
        "discountedPrice": { "type": "number" },
        "discountPercent": { "type": "number" },
        "imageUrl": { "type": "string" },
        "shopeeLink": { "type": "string" },
        "rating": { "type": "number" },
        "salesCount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "originalPrice", "shopeeLink"]
    },
    "JastipOrder": {
      "title": "JastipOrder",
      "description": "A customer Jastip purchase order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "productUrl": { "type": "string" },
        "productName": { "type": "string" },
        "productVariant": { "type": "string" },
        "originalPrice": { "type": "number" },
        "checkoutPrice": { "type": "number" },
        "jastipFee": { "type": "number" },
        "totalPayment": { "type": "number" },
        "status": { "type": "string" },
        "notes": { "type": "string" },
        "recipientName": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "chats": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "sender": { "type": "string" },
              "senderName": { "type": "string" },
              "message": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "userId", "customerName", "customerPhone", "customerAddress", "productUrl", "productName"]
    }
  },
  "firestore": {
    "products": {
      "schema": "ShopeeProduct",
      "description": "Collections of catalog products for Jastip ordering"
    },
    "orders": {
      "schema": "JastipOrder",
      "description": "Collections of all custom Jastip orders and chats"
    }
  }
}
